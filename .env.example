# SabNetra AI Configuration
# Copy this to .env and fill in your values

# RTSP camera URL
SABNETRA_RTSP_URL=rtsp://admin:password@192.168.1.217:554/Streaming/Channels/101

# Model settings
SABNETRA_MODEL_PATH=yolov8n.pt
SABNETRA_DEVICE=cuda:0

# API server
SABNETRA_API_PORT=8000
SABNETRA_API_HOST=0.0.0.0

# Suspect database path
SABNETRA_SUSPECT_DB=suspect_embeddings
