# SabNetra AI 2.0 Environment Configuration
# Copy this file to .env and fill in your values.

# API Authentication (optional). If set, all REST endpoints require
#   Authorization: Bearer <SABNETRA_API_KEY>
# in the request header. Leave empty to disable auth.
SABNETRA_API_KEY=

# RTSP Camera URLs. Configure cameras at runtime via CLI or API, or
# set them here for automatic discovery / config loading.
# Format: RTSP_URL_<CAMERA_ID>=rtsp://user:pass@host:554/stream
# Example:
# RTSP_URL_CAM_0=rtsp://admin:password@192.168.1.100:554/Streaming/Channels/101
